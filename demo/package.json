{
  "name": "terminal-ui-demo",
  "version": "1.0.0",
  "private": true,
  "description": "Demo application showcasing @jonmatum/terminal-ui design system",
  "type": "module",
  "homepage": "https://jonmatum.github.io/terminal-ui",
  "scripts": {
    "dev": "npm run build:package:if-needed && vite",
    "dev:no-build": "vite",
    "build": "npm run build:package:if-needed && npm run build:no-build",
    "build:no-build": "tsc && vite build",
    "build:package": "cd .. && npm run build",
    "build:package:if-needed": "npm run check:package-built || npm run build:package",
    "check:package-built": "test -f ../dist/index.js && test -f ../dist/index.d.ts",
    "preview": "npm run build:package:if-needed && npm run preview:no-build",
    "preview:no-build": "vite preview",
    "deploy": "npm run build && npm run deploy:no-build",
    "deploy:no-build": "gh-pages -d dist",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json,css}\"",
    "clean": "rimraf dist node_modules/.vite",
    "clean:all": "npm run clean && cd .. && npm run clean"
  },
  "dependencies": {
    "@jonmatum/terminal-ui": "file:..",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.17.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "gh-pages": "^6.2.0",
    "globals": "^15.14.0",
    "prettier": "^3.6.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2",
    "vite": "^6.3.5"
  }
}
