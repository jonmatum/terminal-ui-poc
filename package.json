{
  "name": "@jonmatum/terminal-ui",
  "version": "1.0.0",
  "type": "module",
  "description": "Terminal-style design system with Matrix/TRON themes and Konami code integration",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "DESIGN_TOKENS.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "dev:demo": "concurrently \"npm run dev\" \"npm run demo:serve\"",
    "demo:serve": "cd demo && npm run dev:no-build",
    "demo:dev": "npm run build && cd demo && npm run dev:no-build",
    "demo:build": "npm run build && cd demo && npm run build:no-build",
    "demo:preview": "npm run build && cd demo && npm run preview:no-build",
    "demo:deploy": "npm run build && cd demo && npm run deploy:no-build",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json,md}\"",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "analyze:dead-code": "knip",
    "analyze:unused": "knip --include unused",
    "analyze:exports": "knip --include exports",
    "analyze:dependencies": "knip --include dependencies",
    "analyze:all": "knip --include files,dependencies,unlisted,exports,nsExports,classMembers,types,nsTypes,enumMembers,duplicates",
    "bundle-size": "npm run build && bundlesize",
    "quality": "npm run type-check && npm run lint && npm run format:check && npm run test:run",
    "clean": "rimraf dist coverage .nyc_output",
    "prepublishOnly": "npm run clean && npm run quality && npm run build"
  },
  "keywords": [
    "design-system",
    "terminal",
    "matrix",
    "tron",
    "konami",
    "react",
    "typescript",
    "tailwind",
    "micro-frontend",
    "mfe",
    "design-tokens"
  ],
  "author": "Jonmatum",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jonmatum/terminal-ui.git"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.7.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "bundlesize": "^0.18.2",
    "concurrently": "^9.2.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-testing-library": "^7.1.1",
    "eslint-plugin-vitest": "^0.5.4",
    "globals": "^15.14.0",
    "jsdom": "^26.1.0",
    "knip": "^5.62.0",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "rimraf": "^6.0.1",
    "tailwindcss": "^4.1.12",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2",
    "vite": "^6.3.5",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "lucide-react": "^0.539.0",
    "tailwind-merge": "^3.3.1"
  },
  "bundlesize": [
    {
      "path": "./dist/index.cjs",
      "maxSize": "125 kB",
      "compression": "gzip"
    },
    {
      "path": "./dist/index.js",
      "maxSize": "120 kB",
      "compression": "gzip"
    }
  ]
}
